# === Database ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === SweetOffer API ===
MALL_ID=your_mall_id
ACCESS_KEY=your_access_key
SECRET_KEY=your_secret_key
SECRET_KEY_EXPIRES_AT=2025-01-01T00:00:00+09:00
REFRESH_KEY=your_refresh_key
REFRESH_KEY_EXPIRES_AT=2025-01-01T00:00:00+09:00
