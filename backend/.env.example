# === LLM / Embeddings ===
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini          # 답변 생성용
LLM_TEMPERATURE=0.5
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# === LangSmith ===
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=hwabangnet

# === Postgres/pgvector ===
PG_CONN=
PGVECTOR_COLLECTION=processed_content_embeddings

# === Retriever 파라미터 ===
RETRIEVER_SEARCH_TYPE=mmr      # mmr | similarity | similarity_score_threshold 등
RETRIEVER_K=3
RETRIEVER_FETCH_K=20           # (옵션) mmr에서 후보군 수

# === 합성/안전 파라미터 ===
MAX_DOC_CHARS=400              # 각 문서 요약에 사용할 최대 글자
# THREAD_ID_PREFIX=demo-         # LangGraph 체크포인트 thread id prefix

# === 프롬프트 파일 (옵션) ===
SYSTEM_PROMPT_PATH=system_prompt_ko.md
